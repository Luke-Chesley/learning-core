# Service boundary
LEARNING_CORE_HOST=127.0.0.1
LEARNING_CORE_PORT=8000
# LEARNING_CORE_API_KEY=replace-me

# Required runtime defaults
LEARNING_CORE_DEFAULT_TEMPERATURE=0.2
LEARNING_CORE_MAX_TOKENS=4096

# Select exactly one provider profile below and fill in the matching credentials.

# Anthropic profile
LEARNING_CORE_PROVIDER=anthropic
LEARNING_CORE_CHAT_MODEL=claude-haiku-4-5
LEARNING_CORE_FAST_MODEL=claude-haiku-4-5
LEARNING_CORE_GENERATION_MODEL=claude-sonnet-4-5
# LEARNING_CORE_FALLBACK_MODEL=claude-sonnet-4-5
ANTHROPIC_API_KEY=

# OpenAI profile
# LEARNING_CORE_PROVIDER=openai
# LEARNING_CORE_CHAT_MODEL=gpt-5.4-mini
# LEARNING_CORE_FAST_MODEL=gpt-5.4-mini
# LEARNING_CORE_GENERATION_MODEL=gpt-5.4-mini
# LEARNING_CORE_FALLBACK_MODEL=gpt-5.4-mini
# OPENAI_SERVICE_TIER=flex
# OPENAI_API_KEY=

# Ollama / local profile
# LEARNING_CORE_PROVIDER=ollama
# LEARNING_CORE_CHAT_MODEL=gemma3:12b
# LEARNING_CORE_FAST_MODEL=gemma3:12b
# LEARNING_CORE_GENERATION_MODEL=gemma3:12b
# LEARNING_CORE_FALLBACK_MODEL=gemma3:12b
